{
  "name": "vcm-os",
  "displayName": "VCM-OS Memory",
  "description": "Validated Context Memory Operating System for AI coding agents",
  "version": "0.1.0",
  "publisher": "vcm-os",
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Machine Learning",
    "Debuggers",
    "Other"
  ],
  "keywords": [
    "ai",
    "memory",
    "context",
    "agent",
    "kimi"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "views": {
      "explorer": [
        {
          "id": "vcmMemoryPanel",
          "name": "VCM Memory",
          "when": "vcm.enabled"
        }
      ]
    },
    "commands": [
      {
        "command": "vcm.search",
        "title": "Search Memory",
        "category": "VCM",
        "icon": "$(search)"
      },
      {
        "command": "vcm.ingestGit",
        "title": "Ingest Git Changes",
        "category": "VCM",
        "icon": "$(git-commit)"
      },
      {
        "command": "vcm.showState",
        "title": "Show Project State",
        "category": "VCM",
        "icon": "$(info)"
      },
      {
        "command": "vcm.refresh",
        "title": "Refresh Memory Panel",
        "category": "VCM",
        "icon": "$(refresh)"
      },
      {
        "command": "vcm.correctMemory",
        "title": "Correct Memory",
        "category": "VCM",
        "icon": "$(warning)"
      },
      {
        "command": "vcm.enableAutoIngest",
        "title": "Enable Auto-Ingest",
        "category": "VCM"
      },
      {
        "command": "vcm.disableAutoIngest",
        "title": "Disable Auto-Ingest",
        "category": "VCM"
      },
      {
        "command": "vcm.openSettings",
        "title": "Open VCM Settings",
        "category": "VCM",
        "icon": "$(gear)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "vcm.refresh",
          "when": "view == vcmMemoryPanel",
          "group": "navigation"
        },
        {
          "command": "vcm.search",
          "when": "view == vcmMemoryPanel",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vcm.correctMemory",
          "when": "view == vcmMemoryPanel && viewItem == memory",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "VCM-OS",
      "properties": {
        "vcm.apiUrl": {
          "type": "string",
          "default": "http://localhost:8123",
          "description": "VCM-OS API server URL"
        },
        "vcm.projectId": {
          "type": "string",
          "default": "",
          "description": "Project ID (auto-detected from git if empty)"
        },
        "vcm.sessionId": {
          "type": "string",
          "default": "",
          "description": "Session ID (auto-generated if empty)"
        },
        "vcm.autoIngest": {
          "type": "boolean",
          "default": true,
          "description": "Auto-ingest file saves and git changes"
        },
        "vcm.packBudget": {
          "type": "number",
          "default": 500,
          "description": "Default memory pack token budget"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.74.0",
    "typescript": "^5.3.0"
  }
}
